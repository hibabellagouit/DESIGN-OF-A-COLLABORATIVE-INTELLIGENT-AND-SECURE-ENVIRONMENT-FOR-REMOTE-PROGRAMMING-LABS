MONGODB_URI=mongodb://127.0.0.1:27017/projetDB
PORT=5000
JWT_SECRET=change_me_in_.env

# Administrateur créé au démarrage si absent (optionnel)
# SEED_ADMIN_EMAIL=admin@example.com
# SEED_ADMIN_PASSWORD=change_me_strong
# SEED_ADMIN_NAME=Administrateur

# Clé pour créer le tout premier admin via POST /api/admin/first-setup (aucun admin en base)
# ADMIN_FIRST_SETUP_KEY=change_me_bootstrap_secret

# Évaluation automatique (Ollama) — note préliminaire /20
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2
OLLAMA_TIMEOUT_MS=120000

# Sandbox Docker (manuel via « Tester (compose) » — auto désactivé par défaut)
# SANDBOX_AUTO_ON_SUBMIT=true
# SANDBOX_COMPOSE_MODE=balanced
# fast = config + build seulement | balanced = build + conteneurs laissés démarrés (défaut)
# SANDBOX_KEEP_CONTAINERS_UP=true
# SANDBOX_COMPOSE_TEARDOWN=true   # ancien comportement : arrêt des conteneurs après le test
#
# Durcissement sandbox (défaut : activé)
# SANDBOX_COMPOSE_HARDEN=true
# SANDBOX_NETWORK_INTERNAL=false  # défaut si conteneurs laissés actifs : ports accessibles depuis l’hôte (navigateur)
# SANDBOX_NETWORK_INTERNAL=true   # réseau isolé (pas de liens navigateur pour le prof)
# SANDBOX_MEM_LIMIT=512m
# SANDBOX_CPUS=1
# SANDBOX_PIDS_LIMIT=256
# SANDBOX_MAX_CONCURRENT=2          # tests compose simultanés max sur le serveur
# COMPOSE_CONFIG_TIMEOUT_MS=20000
# COMPOSE_BUILD_TIMEOUT_MS=90000
# COMPOSE_UP_TIMEOUT_MS=45000
# GITHUB_TOKEN=ghp_...   # dépôts privés + suivi commits (fortement recommandé)
# GITHUB_COMMITS_MAX_PAGES=3   # si GITHUB_PARTICIPATION_USE_COMMITS=1 (mode détaillé, plus lent)
# GITHUB_PARTICIPATION_USE_COMMITS=1   # optionnel : analyse commit par commit (e-mail) au lieu de /contributors

# File d’attente (sandbox Docker, évaluation Ollama)
# Sans Redis : jobs en mémoire dans le process API (commentez REDIS_URL).
# Avec Redis : démarrez Redis sur le port indiqué, sinon le serveur bascule en mémoire.
# REDIS_URL=redis://127.0.0.1:6379
# QUEUE_RUN_WORKER_IN_API=true
# Worker séparé (si Redis) : npm run worker
# QUEUE_CONCURRENCY=2
#
# API : POST /api/jobs/sandbox | POST /api/jobs/ollama → GET /api/jobs/:id

# Tests d’intégration (npm run test:integration)
# MONGODB_URI_TEST=mongodb://127.0.0.1:27017/tp_projets_integration
# INTEGRATION_USE_MEMORY_MONGO=true

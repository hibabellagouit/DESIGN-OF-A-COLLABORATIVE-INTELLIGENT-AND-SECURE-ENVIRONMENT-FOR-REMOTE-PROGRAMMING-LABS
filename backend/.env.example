MONGODB_URI=mongodb://127.0.0.1:27017/projetDB
PORT=5000
JWT_SECRET=change_me_in_.env

# Administrateur créé au démarrage si absent (optionnel)
# SEED_ADMIN_EMAIL=admin@example.com
# SEED_ADMIN_PASSWORD=change_me_strong
# SEED_ADMIN_NAME=Administrateur

# Clé pour créer le tout premier admin via POST /api/admin/first-setup (aucun admin en base)
# ADMIN_FIRST_SETUP_KEY=change_me_bootstrap_secret

# Docker sandbox (MVP)
SANDBOX_TIMEOUT_MS=6000
SANDBOX_MEMORY=512m
SANDBOX_CPUS=1
SANDBOX_PIDS=128
SANDBOX_NODE_IMAGE=node:20-alpine
SANDBOX_PY_IMAGE=python:3.12-alpine
